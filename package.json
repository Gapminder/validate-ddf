{
  "name": "@gapminder/validate-ddf",
  "version": "2.3.1",
  "description": "DDF validion tool",
  "author": {
    "name": "Semio Zheng and others at Gapminder Foundation",
    "url": "https://www.gapminder.org",
    "email": "info@gapminder.org"
  },
  "contributors": [
    {
      "name": "Semio Zheng",
      "url": "https://github.com/semio",
      "email": "semio@gapminder.org"
    },
    {
      "name": "Angie Hjort",
      "url": "https://github.com/angiehjort",
      "email": "angie@gapminder.org"
    }
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gapminder/validate-ddf"
  },
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "validate-ddf": "src/cli.js"
  },
  "scripts": {
    "clean": "rm -rf node_modules output output-es .spago dist/*.js *.lock .cache",
    "build": "spago build",
    "test": "spago test && npm run test:js",
    "test:js": "node --test test/js-api.test.js",
    "bundle": "npm run build && npm run bundle-app && npm run bundle-module",
    "bundle-app": "purs-backend-es bundle-app --platform=node --to dist/app.js",
    "bundle-module": "purs-backend-es bundle-module --platform=node --to dist/lib.js"
  },
  "files": [
    "dist",
    "src/index.js",
    "src/cli.js"
  ],
  "dependencies": {
    "csv-parse": "^6.1.0",
    "json-stable-stringify": "^1.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "purs-backend-es": "^1.4.2",
    "purs-tidy": "^0.11.1"
  }
}
