  "license": "GPL-3.0",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "validate-ddf-ng": "src/cli.js"
  },
  "scripts": {
    "clean": "rm -rf node_modules output .spago dist/*.js *.lock .cache",
    "build": "spago build",
